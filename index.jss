"","members":"","service_address":"","bank1":"","account1":"","routing1":"","bank2":"","account2":"","routing2":"","biennial":"","name_change_date":"","fka":"","color":null,"is_bold":false,"n":118,"pos":196,"group":"Spindler"},{"type":"entity","entity":"SSP Holdings LLC","state":"","ein":"20-2460047","dos_id":"3170105","exist_date":"","pub_date":"","members_count":"","members":"","service_address":"","bank1":"","account1":"","routing1":"","bank2":"","account2":"","routing2":"","biennial":"","name_change_date":"","fka":"","color":null,"is_bold":false,"n":119,"pos":197,"group":"Spindler"},{"type":"group","title":"Louis"},{"type":"entity","entity":"Silverman Real Estate Group, LLC","state":"","ein":"","dos_id":"3000436","exist_date":"","pub_date":"2007-01-08","members_count":"","members":"","service_address":"","bank1":"","account1":"","routing1":"","bank2":"","account2":"","routing2":"","biennial":"","name_change_date":"","fka":"","color":null,"is_bold":false,"n":120,"pos":201.1,"group":"Silverman Real Estate Group"},{"type":"entity","entity":"East River Development, LLC","state":"New York","ein":"11-3639956","dos_id":"2687986","exist_date":"","pub_date":"","members_count":"","members":"","service_address":"","bank1":"","account1":"","routing1":"","bank2":"","account2":"","routing2":"","biennial":"","name_change_date":"","fka":"","color":null,"is_bold":false,"n":121,"pos":202,"group":"Silverman Real Estate Group"},{"type":"entity","entity":"9th Street Equities, LLC","state":"New York","ein":"","dos_id":"2729292","exist_date":"","pub_date":"2002-03-21","members_count":"","members":"","service_address":"","bank1":"","account1":"","routing1":"","bank2":"","account2":"","routing2":"","biennial":"","name_change_date":"","fka":"","color":null,"is_bold":false,"n":122,"pos":203,"group":"Silverman Real Estate Group"},{"type":"entity","entity":"Stacey Ellen Silverman Lifetime Trust II","state":"","ein":"","dos_id":"","exist_date":"","pub_date":"Entity not found","members_count":"","members":"","service_address":"","bank1":"","account1":"","routing1":"","bank2":"","account2":"","routing2":"","biennial":"","name_change_date":"","fka":"","color":null,"is_bold":false,"n":123,"pos":204.1,"group":"Stacey Ellen Silverman Lifetime Trust II"},{"type":"entity","entity":"Allan Silverman 2014 Family Trust","state":"","ein":"","dos_id":"","exist_date":"","pub_date":"Entity not found","members_count":"","members":"","service_address":"","bank1":"","account1":"","routing1":"","bank2":"","account2":"","routing2":"","biennial":"","name_change_date":"","fka":"","color":null,"is_bold":false,"n":124,"pos":205.1,"group":"Allan Silverman 2014 Family Trust"}];

// ── State ─────────────────────────────────────────────────────────────────────
let openId = null;

// ── Status helpers ────────────────────────────────────────────────────────────

/**
 * Derives a status string from a raw entity record.
 * @param {Object} r - Entity record
 * @returns {'not-found'|'updated'|'full'|'missing-pub'}
 */
function getStatus(r) {
  const pub = r.pub_date || '';
  const ein = r.ein || '';
  const dos = r.dos_id || '';

  if (
    pub.toLowerCase().includes('not found') ||
    ein.toLowerCase().includes('not found') ||
    dos.toLowerCase().includes('not found') ||
    dos === 'Entity not found'
  ) return 'not-found';

  if (r.color === 'FFFF0000') return 'not-found';
  if (r.color === 'FFFFFF00') return 'updated';
  if (r.color === 'FFFFC000') return 'full';
  if (pub.includes('Affidavit')) return 'missing-pub';
  if (!pub) return 'missing-pub';

  return 'updated';
}

/**
 * Returns an HTML badge string for a given status.
 * @param {string} s - Status key
 * @returns {string} HTML string
 */
function statusBadge(s) {
  if (s === 'full')        return '<span class="badge badge-green">✓ Compliant</span>';
  if (s === 'updated')     return '<span class="badge badge-amber">Updated</span>';
  if (s === 'missing-pub') return '<span class="badge badge-red">No cert.</span>';
  if (s === 'not-found')   return '<span class="badge badge-gray">Not found</span>';
  return '';
}

/**
 * Returns the CSS row class for a given status.
 * @param {string} s - Status key
 * @returns {string}
 */
function statusClass(s) {
  if (s === 'full')        return 'rs-full';
  if (s === 'updated')     return 'rs-updated';
  if (s === 'missing-pub') return 'rs-missing';
  if (s === 'not-found')   return 'rs-notfound';
  return '';
}

/**
 * Returns the CSS detail-panel modifier class for a given status.
 * @param {string} s - Status key
 * @returns {string}
 */
function detailClass(s) {
  if (s === 'full')        return 'dr-full';
  if (s === 'updated')     return 'dr-updated';
  if (s === 'missing-pub') return 'dr-missing';
  if (s === 'not-found')   return 'dr-notfound';
  return '';
}

// ── Formatting helpers ────────────────────────────────────────────────────────

/**
 * Formats a raw date/status string for display.
 * @param {string} d
 * @returns {string}
 */
function fmt(d) {
  if (!d || d === '—') return '—';
  if (d.toLowerCase().includes('not found')) return 'Not found';
  if (d.includes('Affidavit')) return 'Affidavit on file';
  return String(d).substring(0, 10);
}

/**
 * Escapes HTML special characters.
 * @param {*} v
 * @returns {string}
 */
function esc(v) {
  return String(v || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

/**
 * Renders a single key-value row inside the detail panel.
 * Returns an empty string if value is empty.
 * @param {string} label
 * @param {string} value
 * @param {boolean} [mono] - Whether to apply monospace styling
 * @returns {string} HTML string
 */
function kv(label, value, mono) {
  if (!value || value === '—') return '';
  return `<div class="kv-row">
    <span class="kv-key">${esc(label)}</span>
    <span class="kv-val${mono ? ' kv-mono' : ''}">${esc(value)}</span>
  </div>`;
}

// ── Initialise data ───────────────────────────────────────────────────────────

// Assign sequential display numbers to entity rows in source order
let _seq = 0;
ITEMS.forEach(r => { if (r.type === 'entity') r._n = ++_seq; });

// Flat array of entity records with status pre-computed
const entityItems = ITEMS
  .filter(x => x.type === 'entity')
  .map(r => { r.status = getStatus(r); return r; });

// Pre-compute how many entity children each group header has
const groupChildCounts = ITEMS.reduce((acc, row, idx) => {
  if (row.type === 'group') {
    let count = 0;
    for (let j = idx + 1; j < ITEMS.length; j++) {
      if (ITEMS[j].type === 'group') break;
      if (ITEMS[j].type === 'entity') count++;
    }
    acc[row.title] = count;
  }
  return acc;
}, {});

// ── Group filter population ───────────────────────────────────────────────────
const groupFilterEl = document.getElementById('filterGroup');
const groupNames = [
  ...new Set(
    ITEMS
      .filter(x => x.type === 'group' && x.title && x.title.trim())
      .map(x => x.title)
  )
];
groupNames.forEach(g => {
  const o = document.createElement('option');
  o.value = g;
  o.textContent = g;
  groupFilterEl.appendChild(o);
});

// Set hero total count once on load
document.getElementById('heroTotal').textContent = entityItems.length;

// ── Main render ───────────────────────────────────────────────────────────────

/**
 * Reads current filter state, re-computes counts, and re-renders the table
 * and all stat displays.
 */
function render() {
  const q       = document.getElementById('search').value.trim().toLowerCase();
  const fStatus = document.getElementById('filterStatus').value;
  const fState  = document.getElementById('filterState').value;
  const fGroup  = document.getElementById('filterGroup').value;

  let n = 0, full = 0, upd = 0, issues = 0;
  const visibleN      = new Set();
  const visibleGroups = new Set();

  // First pass: determine which entity rows match all active filters
  for (const r of entityItems) {
    const matchQ = !q || [
      r.entity, r.state, r.ein, r.dos_id, r.exist_date,
      r.pub_date, r.members, r.bank1, r.bank2,
      r.service_address, r.fka, r.group
    ].join(' ').toLowerCase().includes(q);

    const matchS  = !fStatus || r.status === fStatus;
    const matchSt = !fState  || r.state === fState;
    const matchG  = !fGroup  || r.group === fGroup;

    if (matchQ && matchS && matchSt && matchG) {
      visibleN.add(r.n);
      n++;
      if (r.status === 'full')   full++;
      else if (r.status === 'updated') upd++;
      else issues++;
      if (r.group) visibleGroups.add(r.group);
    }
  }

  // Second pass: build HTML rows including group headers
  const rows = [];
  for (const row of ITEMS) {

    // Group header row
    if (row.type === 'group') {
      const hasChildren = (groupChildCounts[row.title] || 0) > 0;
      const show = !hasChildren || visibleGroups.has(row.title);
      if (show) {
        rows.push(
          `<tr class="group-row">
            <td colspan="6"><span class="group-icon">▸</span>${esc(row.title)}</td>
          </tr>`
        );
      }
      continue;
    }

    // Skip non-visible entity rows
    if (!visibleN.has(row.n)) continue;

    const sc      = statusClass(row.status);
    const dc      = detailClass(row.status);
    const hasFka  = row.fka || row.name_change_date;
    const hasBank2 = row.bank2 && row.bank2 !== 'N/A';

    rows.push(`
      <tr class="row-link ${sc}" onclick="toggle('dr-${row.n}', this)" id="tr-${row.n}">
        <td class="num-cell">${row._n}</td>
        <td class="entity-cell" title="${esc(row.entity)}">${esc(row.entity)}<span class="chevron">›</span></td>
        <td>${esc(row.state || '—')}</td>
        <td style="min-width:110px">${statusBadge(row.status)}</td>
        <td>${esc(fmt(row.exist_date))}</td>
        <td>${esc(fmt(row.pub_date))}</td>
      </tr>
      <tr class="detail-row" id="dr-${row.n}">
        <td colspan="6">
          <div class="detail-inner ${dc}">
            <div class="detail-section">
              <h4>Registration</h4>
              <div class="kv">
                ${kv('EIN', row.ein, true)}
                ${kv('DOS ID', row.dos_id, true)}
                ${kv('Formed', fmt(row.exist_date))}
                ${kv('Cert. of pub.', fmt(row.pub_date))}
                ${kv('Biennial stmt', fmt(row.biennial))}
                ${hasFka ? kv('F/K/A', row.fka) : ''}
                ${row.name_change_date ? kv('Name changed', fmt(row.name_change_date)) : ''}
              </div>
            </div>
            <div class="detail-section">
              <h4>Members</h4>
              <div class="kv">
                ${kv('Count', row.members_count)}
                ${row.members
                  ? `<div class="kv-row">
                       <span class="kv-key">Names</span>
                       <span class="kv-val" style="white-space:normal">${esc(row.members)}</span>
                     </div>`
                  : ''}
                ${row.service_address
                  ? `<div class="kv-row">
                       <span class="kv-key">Service addr.</span>
                       <span class="kv-val" style="white-space:normal;font-size:12px">${esc(row.service_address)}</span>
                     </div>`
                  : ''}
              </div>
            </div>
            <div class="detail-section">
              <h4>Banking</h4>
              <div class="kv">
                ${kv('Bank 1', row.bank1)}
                ${kv('Account', row.account1, true)}
                ${kv('Routing', row.routing1, true)}
                ${hasBank2 ? kv('Bank 2', row.bank2) : ''}
                ${row.account2 ? kv('Account 2', row.account2, true) : ''}
                ${row.routing2 ? kv('Routing 2', row.routing2, true) : ''}
              </div>
            </div>
          </div>
        </td>
      </tr>
    `);
  }

  // Inject rows or empty state
  document.getElementById('tbody').innerHTML = rows.join('') ||
    `<tr><td colspan="6" class="empty">
       <strong>No results</strong>Try adjusting your search or clearing a filter.
     </td></tr>`;

  // Update stat displays
  document.getElementById('count').textContent     = `Showing ${n} of ${entityItems.length} entities`;
  document.getElementById('statTotal').textContent  = n;
  document.getElementById('statFull').textContent   = full;
  document.getElementById('statUpd').textContent    = upd;
  document.getElementById('statIssues').textContent = issues;
  document.getElementById('heroFull').textContent   = full;
  document.getElementById('heroIssues').textContent = upd + issues;
}

// ── Row expand / collapse ─────────────────────────────────────────────────────

/**
 * Toggles the detail row identified by `id`. Collapses any previously open
 * row first.
 * @param {string} id   - ID of the detail <tr> to toggle (e.g. 'dr-12')
 * @param {HTMLElement} trEl - The clicked summary <tr> element
 */
function toggle(id, trEl) {
  const dr = document.getElementById(id);
  if (!dr) return;

  // Collapse previously open row
  if (openId && openId !== id) {
    const prev   = document.getElementById(openId);
    const prevTr = document.getElementById('tr-' + openId.replace('dr-', ''));
    if (prev)   prev.classList.remove('open');
    if (prevTr) prevTr.classList.remove('row-open');
  }

  dr.classList.toggle('open');
  if (trEl) trEl.classList.toggle('row-open');
  openId = dr.classList.contains('open') ? id : null;
}

// ── Event listeners ───────────────────────────────────────────────────────────
document.getElementById('search').addEventListener('input', render);
document.getElementById('filterStatus').addEventListener('change', render);
document.getElementById('filterState').addEventListener('change', render);
document.getElementById('filterGroup').addEventListener('change', render);

document.getElementById('resetBtn').addEventListener('click', () => {
  document.getElementById('search').value        = '';
  document.getElementById('filterStatus').value  = '';
  document.getElementById('filterState').value   = '';
  document.getElementById('filterGroup').value   = '';
  render();
});

// ── Initial render ────────────────────────────────────────────────────────────
render();